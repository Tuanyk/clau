#!/usr/bin/env bash
# clau — chạy Claude Code trong Docker: OAuth + firewall + per-project history
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}")"
CONFIG_DIR="$(dirname "$SCRIPT_PATH")"
IMAGE="claude-base"
CLAUDE_AUTH_VOLUME_BASE="claude-auth"
CODEX_AUTH_VOLUME_BASE="codex-auth"
PIP_VOLUME="clau-pip"
NPM_VOLUME="clau-npm"
TOOLS_VOLUME="clau-tools"
SETTINGS_FILE="$CONFIG_DIR/claude-settings.json"
HOOKS_DIR="$CONFIG_DIR/hooks"
SECRETS_DIR="${CLAU_SECRETS_DIR:-$HOME/.clau/secrets}"
[[ ! -d "$SECRETS_DIR" && -d "$CONFIG_DIR/secrets" ]] && SECRETS_DIR="$CONFIG_DIR/secrets"
ALLOWLISTS_DIR="${CLAU_ALLOWLISTS_DIR:-$HOME/.clau/allowlists}"
[[ ! -d "$ALLOWLISTS_DIR" && -d "$CONFIG_DIR/allowlists" ]] && ALLOWLISTS_DIR="$CONFIG_DIR/allowlists"
TEMPLATES_DIR="$CONFIG_DIR/templates"
DEFAULT_ALLOWLIST="$CONFIG_DIR/allowlist.txt"
[[ -f "$CONFIG_DIR/browser-bridge.sh" ]] && source "$CONFIG_DIR/browser-bridge.sh"
[[ -f "$CONFIG_DIR/auth-profile.sh" ]] && source "$CONFIG_DIR/auth-profile.sh"

usage() {
  cat <<'EOF'
Usage:
  clau [options]
  clau profiles [list]
  clau profiles delete PROFILE [--claude|--codex|--all] [-y|--yes]

Options:
  --claude         Start Claude directly instead of opening a shell.
  --codex          Start Codex directly instead of opening a shell.
  --browser        Let container browser-open requests use the host browser.
  --profile NAME   Use named Claude/Codex auth volumes. Default: default.
  --yolo           Skip tool approvals/sandbox prompts for Claude or Codex.
  --no-firewall    Disable the main AI container URL allowlist for this run.
                   The broker sidecar still keeps its own firewall.
  -h, --help       Show this help and exit.

Common examples:
  clau
  clau --browser
  clau --claude
  clau --claude --profile work
  clau --claude --browser
  clau --codex
  clau --claude --yolo
  clau --codex --yolo
  clau profiles
  clau profiles delete work --codex
  clau --no-firewall
  CLAU_WITH_CODEX_AUTH=1 clau
  CLAU_PORTS=auto:3000,auto:5173 clau
  CLAU_PROJECT_NAME=my-app-personal clau

Important env vars:
  CLAU_PROJECT_NAME          Override project/container/secrets/allowlist name.
  CLAU_PROFILE               Default auth profile when --profile is not passed.
  CLAU_PORTS                 Port forwards. Examples: auto:3000, 3001:3000, or empty to disable.
  CLAU_LOAD_PROJECT_ENV=1    Legacy: load <project>/.env into the AI container.
  CLAU_WITH_CODEX_AUTH=1     Mount Codex auth volume in normal shell/Claude mode.
  CLAU_WITHOUT_AUTH=1        Mount neither Claude nor Codex auth volumes.
  CLAU_SKIP_SNAPSHOT=1       Skip the pre-run project snapshot.
  CLAU_SKIP_AUTO_DOCS=1      Do not seed CLAUDE.md / AGENTS.md into the project.
  CLAU_BROKER_DASHBOARD=1    Publish broker dashboard on 127.0.0.1.
  CLAU_BWRAP_OPTS=0          Keep Docker's default seccomp/AppArmor profiles.

Auth profiles:
  Existing logins use the default profile:
    claude-auth -> /home/dev/.claude
    codex-auth  -> /home/dev/.codex

  Use old/default login:
    clau --claude
    clau --codex
    clau --profile default --claude

  Re-login old/default account:
    clau-login
    codex-login
    clau-login --profile default
    codex-login --profile default

  Add and use another account:
    clau-login --profile work
    codex-login --profile work
    clau --profile work --claude
    clau --profile work --codex

  List/delete auth profiles:
    clau profiles
    clau profiles delete work
    clau profiles delete work --claude
    clau profiles delete work --codex

Secret locations:
  ~/.clau/secrets/<project>/broker/
      Broker-only provider credentials. Use this for Meta, Google Ads, GA4,
      GSC, GTM, and other long-lived provider credentials.

  ~/.clau/secrets/<project>/
      Top-level files are mounted into the AI container under /run/clau-secrets.
      Use this only for values the AI process may read.

  <project>/.env
      Not auto-loaded by default. Still visible in the mounted workspace.

Allowlists:
  Main container:
    <clau-install>/allowlist.txt + ~/.clau/allowlists/<project>.txt

  Broker sidecar:
    ~/.clau/allowlists/broker.txt + ~/.clau/allowlists/<project>-broker.txt

Attach behavior:
  If clau-<project> is already running, clau attaches to it as dev.
  Env vars and mounts from a new command are not applied on attach.
  Stop the container and run clau again to pick up changed secrets or env files.
EOF
}

# ─── Parse flags ────────────────────────────────────────────
if [[ "${1:-}" == "profiles" || "${1:-}" == "profile" ]]; then
  shift
  exec "$CONFIG_DIR/clau-profiles" "$@"
fi

if ! declare -F clau_auth_profile_normalize >/dev/null 2>&1; then
  echo "❌ Auth profile helper not found: $CONFIG_DIR/auth-profile.sh"
  exit 1
fi

NO_FIREWALL=0
DANGER=0
RUN_CLAUDE=0
RUN_CODEX=0
HOST_BROWSER=0
AUTH_PROFILE_RAW="${CLAU_PROFILE:-default}"
while (($#)); do
  case "$1" in
    -h|--help|help)
      usage
      exit 0
      ;;
    --no-firewall) NO_FIREWALL=1 ;;
    --yolo) DANGER=1 ;;  # shortcut: --dangerously-skip-permissions
    --claude) RUN_CLAUDE=1 ;;
    --codex) RUN_CODEX=1 ;;
    --browser) HOST_BROWSER=1 ;;
    --profile)
      shift
      AUTH_PROFILE_RAW="$(clau_auth_parse_profile_arg "${1:-}")" || exit 1
      ;;
    --profile=*)
      AUTH_PROFILE_RAW="${1#*=}"
      AUTH_PROFILE_RAW="$(clau_auth_parse_profile_arg "$AUTH_PROFILE_RAW")" || exit 1
      ;;
    *)
      echo "❌ Unknown option: $1"
      usage
      exit 1
      ;;
  esac
  shift
done

if [[ "$RUN_CLAUDE" -eq 1 && "$RUN_CODEX" -eq 1 ]]; then
  echo "❌ Choose only one direct-run mode: --claude or --codex"
  exit 1
fi
if [[ "$HOST_BROWSER" -eq 1 ]] && ! declare -F clau_browser_bridge_start >/dev/null 2>&1; then
  echo "❌ Browser bridge helper not found: $CONFIG_DIR/browser-bridge.sh"
  exit 1
fi
AUTH_PROFILE="$(clau_auth_profile_normalize "$AUTH_PROFILE_RAW")"
CLAUDE_AUTH_VOLUME="$(clau_auth_volume_name "$CLAUDE_AUTH_VOLUME_BASE" "$AUTH_PROFILE")"
CODEX_AUTH_VOLUME="$(clau_auth_volume_name "$CODEX_AUTH_VOLUME_BASE" "$AUTH_PROFILE")"

# ─── Xác định dự án ─────────────────────────────────────────
# Mặc định PROJECT_NAME lấy từ basename. Hai dự án cùng basename
# ("~/work/my-app" và "~/other/my-app") sẽ collide secrets/allowlist/
# container-name. Override bằng: CLAU_PROJECT_NAME=... clau
PROJECT_DIR="$(pwd)"
if [[ -n "${CLAU_PROJECT_NAME:-}" ]]; then
  raw_name="$CLAU_PROJECT_NAME"
else
  raw_name="$(basename "$PROJECT_DIR")"
fi
# printf '%s' — tránh basename trailing newline bị tr convert thành '-'.
# Trim luôn leading/trailing '-' để ra name sạch.
PROJECT_NAME="$(printf '%s' "$raw_name" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9-' '-')"
PROJECT_NAME="${PROJECT_NAME##-}"
PROJECT_NAME="${PROJECT_NAME%%-}"
CONTAINER_NAME="clau-$PROJECT_NAME"
HISTORY_VOLUME="clau-history-$PROJECT_NAME"
echo "📁 Project: $PROJECT_NAME  ($PROJECT_DIR)"
echo "👤 Auth profile: $AUTH_PROFILE"

# ─── Seed CLAUDE.md / AGENTS.md ─────────────────────────────
# Dùng marker <!-- clau:seed-vN --> để phát hiện "đã seed":
#   - File chưa có      → copy nguyên template
#   - File có + marker  → skip
#   - File có, ko marker → append template (giữ nội dung user)
# Tắt hoàn toàn bằng: export CLAU_SKIP_AUTO_DOCS=1
SEED_MARKER='clau:seed-v1'
if [[ "${CLAU_SKIP_AUTO_DOCS:-0}" != "1" ]]; then
  for doc in CLAUDE.md AGENTS.md; do
    tpl="$TEMPLATES_DIR/$doc"
    dst="$PROJECT_DIR/$doc"
    [[ -f "$tpl" ]] || continue
    if [[ ! -e "$dst" ]]; then
      cp "$tpl" "$dst"
      echo "📝 Seeded $doc (new file; set CLAU_SKIP_AUTO_DOCS=1 to disable)"
    elif ! grep -qF "$SEED_MARKER" "$dst" 2>/dev/null; then
      { printf '\n'; cat "$tpl"; } >> "$dst"
      echo "📝 Appended clau section to existing $doc"
    fi

    # Backfill broker guidance into older seeded files. The seed marker means
    # we normally avoid rewriting user-edited docs, so append this section only
    # when the current template has it and the project copy does not.
    if [[ -e "$dst" ]] \
      && grep -qF "$SEED_MARKER" "$dst" 2>/dev/null \
      && ! grep -qF '## API broker (when `BROKER_URL` is set)' "$dst" 2>/dev/null \
      && grep -qF '## API broker (when `BROKER_URL` is set)' "$tpl" 2>/dev/null; then
      {
        printf '\n'
        sed -n '/^## API broker (when `BROKER_URL` is set)$/,/^## Python \/ tools$/p' "$tpl" | sed '$d'
      } >> "$dst"
      echo "📝 Added clau broker section to $doc"
    fi
  done
fi

# ─── Attach nếu đang chạy ───────────────────────────────────
if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
  echo "📎 Attach to existing $CONTAINER_NAME"
  echo "   ⚠️  Env vars and mounts from this run are NOT applied on attach."
  echo "      To pick up secrets/ or .env changes: docker stop $CONTAINER_NAME && clau"
  if [[ "$HOST_BROWSER" -eq 1 ]]; then
    echo "      --browser also needs a fresh container: docker stop $CONTAINER_NAME && clau --browser"
  fi
  exec docker exec -it \
    --user dev \
    -e HOME=/home/dev \
    -e USER=dev \
    -e LOGNAME=dev \
    -e SHELL=/bin/bash \
    -w "$PROJECT_DIR" \
    "$CONTAINER_NAME" bash
fi

# ─── Snapshot working dir (recovery if AI nukes things) ─────
# Tar the project into ~/.clau/snapshots/<project>/<UTC-timestamp>.tar.gz
# before launching a fresh container. Lives outside the bind mount so the
# container can't reach it. Restore via: clau-restore
# Defaults: keep last 3, prune anything older than 3 days.
# Tunables:
#   CLAU_SKIP_SNAPSHOT=1      disable for this run
#   CLAU_SNAPSHOT_KEEP=N      max snapshots per project (default 3)
#   CLAU_SNAPSHOT_TTL_DAYS=N  auto-prune age (default 3)
#   CLAU_SNAPSHOT_DIR=/path   override storage root (default ~/.clau/snapshots)
clau_snapshot() {
  local snap_root="${CLAU_SNAPSHOT_DIR:-$HOME/.clau/snapshots}"
  local keep="${CLAU_SNAPSHOT_KEEP:-3}"
  local ttl_days="${CLAU_SNAPSHOT_TTL_DAYS:-3}"
  local proj_snap_dir="$snap_root/$PROJECT_NAME"
  local ts out
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  out="$proj_snap_dir/$ts.tar.gz"

  mkdir -p "$proj_snap_dir" 2>/dev/null || {
    echo "⚠️  Cannot create $proj_snap_dir; skipping snapshot."
    return 0
  }

  # Default excludes: reproducible build artifacts. Keeps tarballs small.
  # Glob patterns are single-quoted so bash doesn't expand them against cwd.
  local -a excludes=(
    '--exclude=./node_modules'
    '--exclude=./.venv'
    '--exclude=./venv'
    '--exclude=./__pycache__'
    '--exclude=*.pyc'
    '--exclude=./dist'
    '--exclude=./build'
    '--exclude=./.next'
    '--exclude=./target'
    '--exclude=./.cache'
    '--exclude=./.clau-restored-*'
  )

  # Per-project additions via .clau-snapshot-ignore (gitignore-style, one pattern/line).
  local extra="$PROJECT_DIR/.clau-snapshot-ignore"
  if [[ -f "$extra" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" || "$line" =~ ^# ]] && continue
      excludes+=(--exclude="$line")
    done < "$extra"
  fi

  # --ignore-failed-read: skip files we can't read (e.g. mysql/postgres data dirs
  # owned by container UIDs) and keep the snapshot. Unreadable files aren't
  # recoverable via host tools anyway, so a partial snapshot beats none.
  local rc=0 err_log
  err_log="$(mktemp 2>/dev/null || echo /tmp/clau-tar-err.$$)"
  tar --ignore-failed-read -czf "$out" -C "$PROJECT_DIR" "${excludes[@]}" . 2>"$err_log" || rc=$?
  # tar exit 1 = "some files differed during read" (.git churn) — accept.
  # tar exit ≥2 = fatal (disk full, bad path, etc.).
  if (( rc > 1 )); then
    rm -f "$out" 2>/dev/null || true
    echo "⚠️  Snapshot failed (tar exit $rc); continuing without backup."
    if [[ -s "$err_log" ]]; then
      echo "   tar stderr (first 5 lines):"
      head -5 "$err_log" 2>/dev/null | sed 's/^/     /'
      echo "   Full log: $err_log"
      echo "   To skip the snapshot for this run: CLAU_SKIP_SNAPSHOT=1 clau"
    else
      rm -f "$err_log" 2>/dev/null || true
    fi
    return 0
  fi

  local size
  size="$(du -h "$out" 2>/dev/null | awk '{print $1}')"
  echo "📦 Snapshot: $out ($size)"

  # If tar warned about unreadable files, surface a short note so the user
  # can add them to .clau-snapshot-ignore and silence future runs.
  if [[ -s "$err_log" ]]; then
    local skipped=0
    skipped="$(grep -c 'Permission denied' "$err_log" 2>/dev/null || true)"
    [[ "$skipped" =~ ^[0-9]+$ ]] || skipped=0
    if (( skipped > 0 )); then
      echo "   ($skipped path(s) skipped — permission denied; add to .clau-snapshot-ignore to silence)"
    fi
  fi
  rm -f "$err_log" 2>/dev/null || true

  # Prune by TTL.
  find "$proj_snap_dir" -maxdepth 1 -type f -name '*.tar.gz' \
    -mtime +"$ttl_days" -delete 2>/dev/null || true

  # Cap to $keep newest.
  local n
  n="$(find "$proj_snap_dir" -maxdepth 1 -type f -name '*.tar.gz' 2>/dev/null | wc -l)"
  if (( n > keep )); then
    find "$proj_snap_dir" -maxdepth 1 -type f -name '*.tar.gz' -printf '%T@\t%p\n' 2>/dev/null \
      | sort -n | head -n $((n - keep)) | cut -f2- \
      | xargs -r rm -f 2>/dev/null || true
  fi
}

if [[ "${CLAU_SKIP_SNAPSHOT:-0}" != "1" ]] \
  && [[ -d "$PROJECT_DIR" ]] \
  && [[ -n "$(ls -A "$PROJECT_DIR" 2>/dev/null)" ]]; then
  clau_snapshot
fi

# ─── Check image & auth ─────────────────────────────────────
if ! docker image inspect "$IMAGE" &>/dev/null; then
  echo "❌ Image chưa có. Chạy: $CONFIG_DIR/install.sh"; exit 1
fi

# Auth volumes are created on demand. Use clau-login / codex-login with the same
# profile once to populate them, then credentials persist across container runs.
docker volume inspect "$CLAUDE_AUTH_VOLUME" &>/dev/null || docker volume create "$CLAUDE_AUTH_VOLUME" >/dev/null
docker volume inspect "$CODEX_AUTH_VOLUME" &>/dev/null || docker volume create "$CODEX_AUTH_VOLUME" >/dev/null

# ─── Tạo history volume (per-project) ───────────────────────
docker volume inspect "$HISTORY_VOLUME" &>/dev/null || docker volume create "$HISTORY_VOLUME" >/dev/null

# ─── Tạo pip volume (dùng chung mọi project) ────────────────
docker volume inspect "$PIP_VOLUME" &>/dev/null || docker volume create "$PIP_VOLUME" >/dev/null

# ─── Tạo npm cache volume (dùng chung mọi project) ──────────
docker volume inspect "$NPM_VOLUME" &>/dev/null || docker volume create "$NPM_VOLUME" >/dev/null

# ─── Tạo tools volume (dùng chung mọi project) ──────────────
docker volume inspect "$TOOLS_VOLUME" &>/dev/null || docker volume create "$TOOLS_VOLUME" >/dev/null

# ─── Chọn allowlist ─────────────────────────────────────────
# Project-specific allowlist (allowlists/<project>.txt) is APPENDED to
# default (allowlist.txt), so projects only declare extras (e.g. their own
# API endpoints) without losing access to Anthropic/OpenAI/git/pkg registries.
PROJECT_ALLOWLIST="$ALLOWLISTS_DIR/$PROJECT_NAME.txt"
ALLOWLIST_TO_USE=""
if [[ -f "$DEFAULT_ALLOWLIST" || -f "$PROJECT_ALLOWLIST" ]]; then
  ALLOWLIST_TO_USE="/tmp/clau-allowlist-$PROJECT_NAME.txt"
  : > "$ALLOWLIST_TO_USE"
  if [[ -f "$DEFAULT_ALLOWLIST" ]]; then
    cat "$DEFAULT_ALLOWLIST" >> "$ALLOWLIST_TO_USE"
    # Guarantee newline between files even if default has no trailing one.
    [[ -n "$(tail -c1 "$ALLOWLIST_TO_USE")" ]] && printf '\n' >> "$ALLOWLIST_TO_USE"
  fi
  if [[ -f "$PROJECT_ALLOWLIST" ]]; then
    printf '# Project: %s\n' "$PROJECT_NAME" >> "$ALLOWLIST_TO_USE"
    cat "$PROJECT_ALLOWLIST" >> "$ALLOWLIST_TO_USE"
    echo "🔥 Firewall allowlist: default + $PROJECT_ALLOWLIST"
  fi
fi

# ─── Env files ──────────────────────────────────────────────
# Hỗ trợ hai layout:
#   secrets/<project>.env          (legacy, chỉ env vars)
#   secrets/<project>/             (đầy đủ: .env + credential files)
ENV_FILES=()
PROJECT_FILE_SECRETS="$SECRETS_DIR/$PROJECT_NAME"
[[ -f "$SECRETS_DIR/$PROJECT_NAME.env" ]] && ENV_FILES+=(--env-file "$SECRETS_DIR/$PROJECT_NAME.env")
[[ -f "$PROJECT_FILE_SECRETS/.env" ]]     && ENV_FILES+=(--env-file "$PROJECT_FILE_SECRETS/.env")
if [[ -f "$PROJECT_DIR/.env" ]]; then
  if [[ "${CLAU_LOAD_PROJECT_ENV:-0}" == "1" ]]; then
    ENV_FILES+=(--env-file "$PROJECT_DIR/.env")
    echo "⚠️  Loading project .env because CLAU_LOAD_PROJECT_ENV=1. It is visible in the mounted workspace."
  else
    echo "⚠️  Project .env exists but is not auto-loaded. It is still visible in the mounted workspace."
    echo "   Move high-value credentials to the broker; set CLAU_LOAD_PROJECT_ENV=1 only for legacy runs."
  fi
fi

# ─── Port helpers (used by broker dashboard and dev-server forwarding) ──
CLAU_PORT_SCAN_LIMIT="${CLAU_PORT_SCAN_LIMIT:-200}"
reserved_host_ports=()

host_port_is_reserved() {
  local port="$1"
  local reserved
  for reserved in "${reserved_host_ports[@]}"; do
    [[ "$reserved" == "$port" ]] && return 0
  done
  return 1
}

valid_tcp_port() {
  local port="$1"
  [[ "$port" =~ ^[0-9]+$ ]] && (( 10#$port >= 1 && 10#$port <= 65535 ))
}

host_port_is_available() {
  local port="$1"
  if command -v ss >/dev/null 2>&1; then
    [[ -z "$(ss -H -ltn "sport = :$port" 2>/dev/null)" ]]
  elif command -v lsof >/dev/null 2>&1; then
    ! lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
  else
    ! (: >"/dev/tcp/127.0.0.1/$port") >/dev/null 2>&1
  fi
}

find_available_host_port() {
  local start="$1"
  local limit="$2"
  local end=$((start + limit))
  local port="$start"
  (( end > 65535 )) && end=65535
  while (( port <= end )); do
    if ! host_port_is_reserved "$port" && host_port_is_available "$port"; then
      printf '%s\n' "$port"
      return 0
    fi
    port=$((port + 1))
  done
  return 1
}

# ─── Sidecar broker (per-project) ───────────────────────────
# Nếu secrets/<project>/broker/ tồn tại thì project ở "brokered mode":
#   - Spin up broker-<project> container giữ API creds (Meta token, GA SA,
#     Google Ads developer token, ...). Broker mount creds read-only ở
#     /run/broker-secrets, expose FastAPI :8080 trên docker network riêng.
#   - clau-<project> tham gia cùng network, nhận BROKER_URL/BROKER_IP/BROKER_PORT.
#     Claude KHÔNG có creds — chỉ gọi http://broker:8080/... còn broker
#     inject Authorization rồi forward tới Meta / Google.
# Nếu thư mục không tồn tại → behavior như cũ, không có broker container.
BROKER_DIR="$PROJECT_FILE_SECRETS/broker"
BROKER_ENABLED=0
BROKER_NETWORK=""
BROKER_IP=""
BROKER_PORT=8080
BROKER_AUTH_TOKEN=""
if [[ -d "$BROKER_DIR" ]]; then
  BROKER_IMAGE="clau-broker"
  if ! docker image inspect "$BROKER_IMAGE" &>/dev/null; then
    echo "⚠️  Broker image chưa có ($BROKER_IMAGE). Skip broker. Build: $CONFIG_DIR/install.sh"
  else
    if ! BROKER_AUTH_TOKEN="$(od -An -N32 -tx1 /dev/urandom | tr -d ' \n')" || [[ -z "$BROKER_AUTH_TOKEN" ]]; then
      echo "❌ Could not generate broker auth token."
      exit 1
    fi
    BROKER_NETWORK="clau-net-$PROJECT_NAME"
    BROKER_NAME="broker-$PROJECT_NAME"
    BROKER_ALLOWLIST="$ALLOWLISTS_DIR/broker.txt"
    BROKER_PROJECT_ALLOWLIST="$ALLOWLISTS_DIR/$PROJECT_NAME-broker.txt"

    # Compose broker allowlist: shared + per-project extras (if any).
    BROKER_ALLOW_TMP="/tmp/clau-broker-allow-$PROJECT_NAME.txt"
    : > "$BROKER_ALLOW_TMP"
    [[ -f "$BROKER_ALLOWLIST" ]] && cat "$BROKER_ALLOWLIST" >> "$BROKER_ALLOW_TMP"
    [[ -n "$(tail -c1 "$BROKER_ALLOW_TMP" 2>/dev/null)" ]] && printf '\n' >> "$BROKER_ALLOW_TMP"
    if [[ -f "$BROKER_PROJECT_ALLOWLIST" ]]; then
      printf '# Project: %s (broker)\n' "$PROJECT_NAME" >> "$BROKER_ALLOW_TMP"
      cat "$BROKER_PROJECT_ALLOWLIST" >> "$BROKER_ALLOW_TMP"
    fi

    docker network inspect "$BROKER_NETWORK" &>/dev/null \
      || docker network create "$BROKER_NETWORK" >/dev/null

    BROKER_READY=0
    # Recreate on every fresh clau run so credentials and the per-run auth token
    # cannot drift from the paired AI container.
    docker rm -f "$BROKER_NAME" &>/dev/null || true

    DASHBOARD_BASE_PORT="${CLAU_BROKER_DASHBOARD_PORT:-19000}"
    DASHBOARD_PUBLISH=()
    if [[ "${CLAU_BROKER_DASHBOARD:-0}" == "1" ]]; then
      if dashboard_host_port="$(find_available_host_port "$DASHBOARD_BASE_PORT" "$CLAU_PORT_SCAN_LIMIT")"; then
        DASHBOARD_PUBLISH=(-p "127.0.0.1:$dashboard_host_port:$BROKER_PORT")
        reserved_host_ports+=("$dashboard_host_port")
      else
        echo "⚠️  No free host port for broker dashboard near $DASHBOARD_BASE_PORT — dashboard will only be reachable from inside the docker network"
      fi
    else
      echo "📊 Broker dashboard host publish disabled. Set CLAU_BROKER_DASHBOARD=1 to publish it on 127.0.0.1."
    fi

    docker run -d \
      --name "$BROKER_NAME" \
      --network "$BROKER_NETWORK" \
      --network-alias broker \
      --cap-add=NET_ADMIN --cap-add=NET_RAW \
      "${DASHBOARD_PUBLISH[@]}" \
      -e CLAU_FIREWALL=1 \
      -e "CLAU_INBOUND_PORTS=$BROKER_PORT" \
      -e "BROKER_AUTH_TOKEN=$BROKER_AUTH_TOKEN" \
      -v "$CONFIG_DIR/broker/entrypoint.sh:/entrypoint.sh:ro" \
      -v "$CONFIG_DIR/init-firewall.sh:/usr/local/bin/init-firewall.sh:ro" \
      -v "$BROKER_DIR:/run/broker-secrets:ro" \
      -v "$BROKER_ALLOW_TMP:/etc/allowlist.txt:ro" \
      "$BROKER_IMAGE" >/dev/null
    # Wait for broker to be reachable (≤8s).
    for _ in $(seq 1 16); do
      docker exec "$BROKER_NAME" sh -c \
        'curl -fs -m 1 -H "Authorization: Bearer $BROKER_AUTH_TOKEN" http://127.0.0.1:8080/health' &>/dev/null && {
          BROKER_READY=1
          break
        }
      docker ps --format '{{.Names}}' | grep -q "^${BROKER_NAME}$" || break
      sleep 0.5
    done

    if [[ "$BROKER_READY" -ne 1 ]]; then
      echo "❌ Broker $BROKER_NAME did not start cleanly."
      if [[ "${CLAU_BROKER_SHOW_LOGS:-0}" == "1" ]]; then
        echo "   Recent logs:"
        docker logs --tail 80 "$BROKER_NAME" 2>&1 | sed 's/^/   /' || true
      else
        echo "   Logs are available with: docker logs --tail 80 $BROKER_NAME"
      fi
      echo "   Fix the broker error above, then run: docker rm -f $BROKER_NAME && clau"
      echo "   To disable broker mode for this project, remove or rename: $BROKER_DIR"
      exit 1
    fi

    if ! BROKER_IP="$(docker inspect -f \
      "{{(index .NetworkSettings.Networks \"$BROKER_NETWORK\").IPAddress}}" \
      "$BROKER_NAME")"; then
      echo "❌ Broker $BROKER_NAME is not inspectable after startup."
      if [[ "${CLAU_BROKER_SHOW_LOGS:-0}" == "1" ]]; then
        echo "   Recent logs:"
        docker logs --tail 80 "$BROKER_NAME" 2>&1 | sed 's/^/   /' || true
      else
        echo "   Logs are available with: docker logs --tail 80 $BROKER_NAME"
      fi
      exit 1
    fi

    if [[ -z "$BROKER_IP" ]]; then
      echo "❌ Không lấy được IP broker $BROKER_NAME trên network $BROKER_NETWORK."
      exit 1
    else
      BROKER_ENABLED=1
      echo "🤝 Broker: $BROKER_NAME ($BROKER_IP:$BROKER_PORT) on $BROKER_NETWORK"
      DASHBOARD_HOST_BIND="$(docker port "$BROKER_NAME" "$BROKER_PORT" 2>/dev/null | head -1 || true)"
      if [[ -n "$DASHBOARD_HOST_BIND" ]]; then
        echo "📊 Dashboard: http://${DASHBOARD_HOST_BIND/0.0.0.0/127.0.0.1}/dashboard (requires Authorization header)"
      fi
    fi
  fi
fi

# ─── Volumes ────────────────────────────────────────────────
MOUNTS=(
  -v "$PROJECT_DIR:$PROJECT_DIR"
  -v "$HISTORY_VOLUME:/home/dev/.history-store"
  -v "$PIP_VOLUME:/home/dev/.pip-user"
  -v "$NPM_VOLUME:/home/dev/.npm"
  -v "$TOOLS_VOLUME:/opt/clau-tools"
)
if [[ "${CLAU_WITHOUT_AUTH:-0}" == "1" ]]; then
  echo "🔐 Auth volumes: not mounted (CLAU_WITHOUT_AUTH=1)"
elif [[ "$RUN_CODEX" -eq 1 ]]; then
  MOUNTS+=(-v "$CODEX_AUTH_VOLUME:/home/dev/.codex")
  echo "🔐 Auth volume: Codex only"
else
  MOUNTS+=(-v "$CLAUDE_AUTH_VOLUME:/home/dev/.claude")
  echo "🔐 Auth volume: Claude only"
  if [[ "${CLAU_WITH_CODEX_AUTH:-0}" == "1" ]]; then
    MOUNTS+=(-v "$CODEX_AUTH_VOLUME:/home/dev/.codex")
    echo "🔐 Auth volume: Codex also mounted because CLAU_WITH_CODEX_AUTH=1"
  fi
fi

# ─── Port forwarding cho dev servers ────────────────────────
# Mặc định map host port tự động từ 13000 tới container port 3000.
# Override bằng:
#   CLAU_PORTS=3001:3000 clau   # fixed host:container
#   CLAU_PORTS=auto:3000 clau   # auto host port -> container 3000
#   CLAU_PORTS=auto:3000,auto:5173 clau
# Disable hoàn toàn:
#   CLAU_PORTS="" clau
# Bind vào 127.0.0.1 để không lộ ra LAN.
CLAU_DEFAULT_HOST_PORT="${CLAU_DEFAULT_HOST_PORT:-13000}"
CLAU_DEFAULT_CONTAINER_PORT="${CLAU_DEFAULT_CONTAINER_PORT:-3000}"
CLAU_PORTS_RAW="${CLAU_PORTS-auto:$CLAU_DEFAULT_CONTAINER_PORT}"
PORT_OPTS=()
exposed_ports=()
inbound_ports=()

if ! valid_tcp_port "$CLAU_DEFAULT_HOST_PORT" || ! valid_tcp_port "$CLAU_DEFAULT_CONTAINER_PORT" || [[ ! "$CLAU_PORT_SCAN_LIMIT" =~ ^[0-9]+$ ]]; then
  echo "❌ CLAU_DEFAULT_HOST_PORT/CLAU_DEFAULT_CONTAINER_PORT phải là TCP port hợp lệ; CLAU_PORT_SCAN_LIMIT phải là số"
  exit 1
fi

for port_spec in ${CLAU_PORTS_RAW//,/ }; do
  [[ -z "$port_spec" ]] && continue
  if [[ "$port_spec" == "auto" ]]; then
    host_port="auto"
    container_port="$CLAU_DEFAULT_CONTAINER_PORT"
  elif [[ "$port_spec" == *:* ]]; then
    host_port="${port_spec%%:*}"
    container_port="${port_spec##*:}"
  else
    host_port="$port_spec"
    container_port="$port_spec"
  fi
  if { [[ "$host_port" != "auto" ]] && ! valid_tcp_port "$host_port"; } || ! valid_tcp_port "$container_port"; then
    echo "❌ CLAU_PORTS không hợp lệ: $port_spec"
    echo "   Dùng dạng: CLAU_PORTS=3001:3000 hoặc CLAU_PORTS=auto:3000"
    exit 1
  fi

  if [[ "$host_port" == "auto" ]]; then
    if ! host_port="$(find_available_host_port "$CLAU_DEFAULT_HOST_PORT" "$CLAU_PORT_SCAN_LIMIT")"; then
      echo "❌ Không tìm được host port trống từ $CLAU_DEFAULT_HOST_PORT"
      echo "   Thử: CLAU_DEFAULT_HOST_PORT=14000 clau"
      exit 1
    fi
  elif host_port_is_reserved "$host_port"; then
    echo "❌ Host port $host_port bị khai báo trùng trong CLAU_PORTS"
    exit 1
  elif ! host_port_is_available "$host_port"; then
    echo "❌ Host port $host_port đang được dùng"
    echo "   Thử: CLAU_PORTS=auto:$container_port clau"
    exit 1
  fi

  PORT_OPTS+=(-p "127.0.0.1:${host_port}:${container_port}")
  reserved_host_ports+=("$host_port")
  exposed_ports+=("localhost:$host_port->$container_port")
  inbound_ports+=("$container_port")
done
[[ ${#exposed_ports[@]} -gt 0 ]] && echo "🌐 Ports: ${exposed_ports[*]} (host->container)"

# ─── File-based secrets auto-injection ──────────────────────
# Mỗi file trong secrets/<project>/ (trừ .env) sẽ được mount vào
# /run/clau-secrets/ và auto-inject path làm env var:
#   gcp.json      → GCP_JSON=/run/clau-secrets/gcp.json
#                 + GOOGLE_APPLICATION_CREDENTIALS=... (well-known alias)
#   kubeconfig    → KUBECONFIG=/run/clau-secrets/kubeconfig
#   id_ed25519    → ID_ED25519=/run/clau-secrets/id_ed25519
EXTRA_ENV=()
if [[ "$HOST_BROWSER" -eq 1 ]]; then
  clau_browser_bridge_start "$CONTAINER_NAME" || exit 1
  trap clau_browser_bridge_stop EXIT
  MOUNTS+=("${CLAU_BROWSER_BRIDGE_DOCKER_ARGS[@]}")
  EXTRA_ENV+=("${CLAU_BROWSER_BRIDGE_ENV[@]}")
fi
if [[ -d "$PROJECT_FILE_SECRETS" ]]; then
  secret_tmpfs_added=0
  injected=()
  while IFS= read -r -d '' f; do
    fname="$(basename "$f")"
    [[ "$fname" == ".env" ]] && continue
    if [[ "$secret_tmpfs_added" -eq 0 ]]; then
      MOUNTS+=(--tmpfs /run/clau-secrets:mode=755)
      secret_tmpfs_added=1
    fi
    MOUNTS+=(-v "$f:/run/clau-secrets/$fname:ro")
    # Normalize: uppercase, mọi char không phải [A-Z0-9] → _, trim _.
    var="$(printf '%s' "$fname" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9' '_')"
    var="${var##_}"; var="${var%%_}"
    [[ "$var" =~ ^[0-9] ]] && var="_$var"
    [[ -z "$var" ]] && continue
    EXTRA_ENV+=(-e "${var}=/run/clau-secrets/$fname")
    injected+=("$var")
    # Well-known aliases
    case "$fname" in
      gcp.json|service-account.json|gcp-*.json|*-gcp.json)
        EXTRA_ENV+=(-e "GOOGLE_APPLICATION_CREDENTIALS=/run/clau-secrets/$fname")
        injected+=("GOOGLE_APPLICATION_CREDENTIALS")
        ;;
      kubeconfig|kubeconfig.yaml|kubeconfig.yml)
        EXTRA_ENV+=(-e "KUBECONFIG=/run/clau-secrets/$fname")
        injected+=("KUBECONFIG")
        ;;
    esac
  done < <(find "$PROJECT_FILE_SECRETS" -maxdepth 1 -type f -print0)
  if [[ ${#injected[@]} -gt 0 ]]; then
    echo "🔑 File secrets: top-level files in $PROJECT_FILE_SECRETS → /run/clau-secrets (ro)"
    echo "   Injected env vars: ${injected[*]}"
  fi
  if [[ -d "$BROKER_DIR" ]]; then
    echo "🔐 Broker secrets: $BROKER_DIR → broker only (not mounted into AI container)"
  fi
fi

# Policy (deny rules + hooks) ở managed-settings path — admin-scope, read-only,
# override cả user/project settings. User vẫn ghi được ~/.claude/settings.json
# (theme, model, effort, ...) mà không vướng EROFS.
[[ -f "$SETTINGS_FILE" ]] && MOUNTS+=(-v "$SETTINGS_FILE:/etc/claude-code/managed-settings.json:ro")
[[ -d "$HOOKS_DIR" ]] && MOUNTS+=(-v "$HOOKS_DIR:/etc/clau/hooks:ro")
[[ -f "$CONFIG_DIR/init-firewall.sh" ]] && MOUNTS+=(-v "$CONFIG_DIR/init-firewall.sh:/usr/local/bin/init-firewall.sh:ro")
# Bind-mount entrypoint.sh so edits take effect without rebuilding the image
# (matches the init-firewall.sh pattern above).
[[ -f "$CONFIG_DIR/entrypoint.sh" ]] && MOUNTS+=(-v "$CONFIG_DIR/entrypoint.sh:/entrypoint.sh:ro")

# Mount allowlist nếu có và firewall không bị disable
FIREWALL_OPTS=()
if [[ -n "$ALLOWLIST_TO_USE" && "$NO_FIREWALL" -eq 0 ]]; then
  MOUNTS+=(-v "$ALLOWLIST_TO_USE:/etc/allowlist.txt:ro")
  FIREWALL_OPTS+=(
    --cap-add=NET_ADMIN --cap-add=NET_RAW
    -e CLAU_FIREWALL=1
  )
  # Open INPUT for the container ports we just published, otherwise the
  # firewall's default-DROP swallows inbound from the docker bridge and
  # `localhost:<host_port>` times out.
  if (( ${#inbound_ports[@]} > 0 )); then
    FIREWALL_OPTS+=(-e "CLAU_INBOUND_PORTS=$(IFS=,; echo "${inbound_ports[*]}")")
  fi
elif [[ "$NO_FIREWALL" -eq 1 ]]; then
  echo "⚠️  Firewall disabled (--no-firewall) — DNS log: ~/.history-store/traffic.log"
  FIREWALL_OPTS+=(
    --cap-add=NET_RAW --cap-add=NET_ADMIN
    -e CLAU_TRAFFIC_LOG=/home/dev/.history-store/traffic.log
  )
fi

# Broker network + env. Khi BROKER_ENABLED=1, gắn clau container vào docker
# network của broker và inject BROKER_URL/BROKER_IP/BROKER_PORT để init-firewall.sh
# whitelist được broker IP (cổng 8080, không nằm trong ipset 443/80).
NETWORK_OPTS=()
if [[ "$BROKER_ENABLED" -eq 1 ]]; then
  NETWORK_OPTS+=(--network "$BROKER_NETWORK")
  EXTRA_ENV+=(
    -e "BROKER_URL=http://broker:$BROKER_PORT"
    -e "BROKER_IP=$BROKER_IP"
    -e "BROKER_PORT=$BROKER_PORT"
    -e "BROKER_AUTH_TOKEN=$BROKER_AUTH_TOKEN"
  )
fi

# Codex uses bubblewrap for its command sandbox. Inside Docker on Linux, the
# default seccomp/AppArmor profile commonly blocks the nested namespace/mount
# operations before commands run. Relax only those outer Docker profiles so
# Codex can still apply its own inner sandbox. Set CLAU_BWRAP_OPTS=0 to disable.
BWRAP_OPTS=()
if [[ "$(uname)" == "Linux" && "${CLAU_BWRAP_OPTS:-1}" != "0" ]]; then
  BWRAP_OPTS+=(--security-opt seccomp=unconfined --security-opt apparmor=unconfined)
fi

if docker ps -a --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
  docker rm "$CONTAINER_NAME" &>/dev/null
fi

unset ANTHROPIC_API_KEY
unset OPENAI_API_KEY

# ─── Entry command: persist bash_history qua volume ─────────
# Map .bash_history vào /home/dev/.history-store/bash_history
# Fix perms: Docker tạo named volume với owner root; chown về dev lần đầu.
# In env summary sau khi start (chỉ chạy trên fresh docker run, không trên attach).
ENTRY_CMD='
mkdir -p ~/.history-store
touch ~/.history-store/bash_history
ln -sf ~/.history-store/bash_history ~/.bash_history
echo "✓ $(hostname) — firewall: $([ -n \"$CLAU_FIREWALL\" ] && echo ON || echo OFF)"
echo ""
echo "─── Env vars available (names only) ───"
env | cut -d= -f1 | sort \
  | grep -v -E "^(_|HOME|HOSTNAME|LANG|LC_[A-Z_]+|LINES|COLUMNS|PATH|PWD|SHLVL|TERM|USER|LOGNAME|SHELL|MAIL|OLDPWD)$" \
  | sed "s/^/  /"
if [ -d /run/clau-secrets ] && [ -n "$(ls -A /run/clau-secrets 2>/dev/null)" ]; then
  echo "─── /run/clau-secrets files ───"
  ls -1 /run/clau-secrets | sed "s/^/  /"
fi
if [ -n "$BROKER_URL" ]; then
  echo "─── API broker (use this for Meta / Google Ads / GA4 / GSC) ───"
  echo "  $BROKER_URL"
  echo "  Auth header: Authorization: Bearer \$BROKER_AUTH_TOKEN"
  echo "  Provider hosts (graph.facebook.com, googleads.googleapis.com, ...) are firewalled off."
  echo "  Endpoints: GET /health, /docs   POST /meta/insights, /ga4/run-report, /gsc/search-analytics, /google-ads/query"
fi
echo ""
echo "Type: claude, codex, or env | sort for full list"
'
if [[ "$RUN_CODEX" -eq 1 && "$DANGER" -eq 1 ]]; then
  ENTRY_CMD+='echo "  ⚡ --yolo mode: sẽ chạy codex --dangerously-bypass-approvals-and-sandbox";'
  ENTRY_CMD+='exec bash -c "codex --dangerously-bypass-approvals-and-sandbox; exec bash"'
elif [[ "$RUN_CODEX" -eq 1 ]]; then
  ENTRY_CMD+='exec bash -c "codex; exec bash"'
elif [[ "$RUN_CLAUDE" -eq 1 && "$DANGER" -eq 1 ]]; then
  ENTRY_CMD+='echo "  ⚡ --yolo mode: sẽ chạy claude --dangerously-skip-permissions";'
  ENTRY_CMD+='exec bash -c "claude --dangerously-skip-permissions; exec bash"'
elif [[ "$RUN_CLAUDE" -eq 1 ]]; then
  ENTRY_CMD+='exec bash -c "claude; exec bash"'
elif [[ "$DANGER" -eq 1 ]]; then
  ENTRY_CMD+='echo "  ⚡ --yolo mode: sẽ chạy claude --dangerously-skip-permissions";'
  ENTRY_CMD+='exec bash -c "claude --dangerously-skip-permissions; exec bash"'
else
  ENTRY_CMD+='exec bash'
fi

echo "🚀 $CONTAINER_NAME"
DOCKER_RUN_CMD=(
  docker run -it --rm
  --name "$CONTAINER_NAME"
  --hostname "$PROJECT_NAME"
  -e ANTHROPIC_API_KEY=
  -e OPENAI_API_KEY=
  -e CODEX_HOME=/home/dev/.codex
  -e PIP_USER=1
  -e PIP_BREAK_SYSTEM_PACKAGES=1
  -e PYTHONUSERBASE=/home/dev/.pip-user
  "${FIREWALL_OPTS[@]}"
  "${BWRAP_OPTS[@]}"
  "${NETWORK_OPTS[@]}"
  "${PORT_OPTS[@]}"
  "${EXTRA_ENV[@]}"
  "${ENV_FILES[@]}"
  "${MOUNTS[@]}"
  -w "$PROJECT_DIR"
  "$IMAGE"
  bash -c "$ENTRY_CMD"
)

if [[ "$HOST_BROWSER" -eq 1 ]]; then
  "${DOCKER_RUN_CMD[@]}"
  exit $?
fi

exec "${DOCKER_RUN_CMD[@]}"
