#!/usr/bin/env bash
set -euo pipefail

IMAGE="${CLAU_IMAGE:-claude-base}"
# Volume names match clau:11-13.
TOOLS_VOLUME="clau-tools"
NPM_VOLUME="clau-npm"

usage() {
  cat <<'EOF'
Usage:
  clau-update

Refresh Claude Code, OpenAI Codex, and Google Gemini CLI binaries in the
persistent `clau-tools` Docker volume. Runs an ephemeral container — no
image rebuild — so toolbelt layers (apt/pip packages, scratchpad) are not
touched.
EOF
}

for arg in "$@"; do
  case "$arg" in
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "❌ Unknown option: $arg"
      usage
      exit 1
      ;;
  esac
done

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  echo "❌ Image '$IMAGE' not found. Run ./install.sh first." >&2
  exit 1
fi

echo "📦 Refreshing AI CLIs in volume: $TOOLS_VOLUME"

docker run --rm \
  -v "$TOOLS_VOLUME:/opt/clau-tools" \
  -v "$NPM_VOLUME:/home/dev/.npm" \
  "$IMAGE" \
  bash -c '
    set -euo pipefail
    npm install -g --prefix=/opt/clau-tools @openai/codex@latest
    npm install -g --prefix=/opt/clau-tools @google/gemini-cli@latest
    curl -fsSL https://claude.ai/install.sh | bash
    if [ -x "$HOME/.local/bin/claude" ]; then
      install -m 0755 "$HOME/.local/bin/claude" /opt/clau-tools/bin/claude
    elif command -v claude >/dev/null 2>&1; then
      install -m 0755 "$(command -v claude)" /opt/clau-tools/bin/claude
    else
      echo "❌ Claude installer did not produce a claude binary" >&2
      exit 1
    fi
  '

echo "✓ CLIs refreshed in $TOOLS_VOLUME. Restart any running clau containers to pick them up."
