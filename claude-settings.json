{
  "permissions": {
    "deny": [
      "Read(/root/**)",
      "Read(/run/secrets/**)",
      "Read(/proc/*/environ)",
      "Read(/etc/clau/**)",
      "Bash(printenv)",
      "Bash(printenv:*)",
      "Bash(env)",
      "Bash(env:*)",
      "Bash(set)",
      "Bash(declare)",
      "Bash(declare:*)",
      "Bash(export)",
      "Bash(cat:/root/**)",
      "Bash(cat:/run/secrets/**)",
      "Bash(cat:/proc/*/environ)",
      "Bash(cat:/etc/clau/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/clau/hooks/secrets-guard.py"
          }
        ]
      }
    ]
  }
}
